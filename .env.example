# ─── Server ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/db?schema=public

# Generate with: openssl rand -hex 32
JWT_SECRET=your-64-char-random-string-here
JWT_REFRESH_SECRET=another-64-char-random-string-here

PORT=8080
NODE_ENV=production

# ─── Client (Vite build time) ─────────────────────────────────────────────────
# Relative — Express serves the frontend, so /api works without full URL
VITE_API_URL=/api
